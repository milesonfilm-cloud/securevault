# REPLACE THE VALUES BELOW WITH YOUR ACTUAL KEYS IF NOT AUTOMATICALLY SET

NEXT_PUBLIC_SUPABASE_URL=https://dummy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummykey.updateyourkkey.here
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-google-analytics-id-here
NEXT_PUBLIC_ADSENSE_ID=your-adsense-id-here
PERPLEXITY_API_KEY=your-perplexity-api-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here

NEXT_PUBLIC_SITE_URL=https://securevaul6263.builtwithrocket.new
# Local: next dev runs on port 4028 — for DigiLocker OAuth, set this to http://localhost:4028
# and register http://localhost:4028/api/digilocker/callback in the DigiLocker portal.

# Google Identity Services — Drive appDataFolder backup (encrypted vault blob only)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: Resend API for emergency contact emails (see /api/emergency/notify)
RESEND_API_KEY=
EMERGENCY_FROM_EMAIL=

# DigiLocker OAuth (Meri Pehchaan production) — redirect URI must be {NEXT_PUBLIC_SITE_URL}/api/digilocker/callback
NEXT_PUBLIC_DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
# Optional: override issued-docs URL (default: https://digilocker.meripehchaan.gov.in/public/oauth2/2/files/issued)
# DIGILOCKER_ISSUED_URL=
