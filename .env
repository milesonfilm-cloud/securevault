# REPLACE THE VALUES BELOW WITH YOUR ACTUAL KEYS IF NOT AUTOMATICALLY SET

NEXT_PUBLIC_SUPABASE_URL=https://dummy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummykey.updateyourkkey.here
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-google-analytics-id-here
NEXT_PUBLIC_ADSENSE_ID=your-adsense-id-here
PERPLEXITY_API_KEY=your-perplexity-api-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here

NEXT_PUBLIC_SITE_URL=https://securevaul6263.builtwithrocket.new

# Google Identity Services — Drive appDataFolder backup (encrypted vault blob only).
# Create an OAuth 2.0 Web client in Google Cloud Console and paste the client ID (ends in .apps.googleusercontent.com).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# DigiLocker OAuth — app key + secret from DigiLocker / API Setu partner registration (Meri Pehchaan).
# Redirect URI in the portal must exactly match: {NEXT_PUBLIC_SITE_URL}/api/digilocker/callback
# Local dev (port 4028): NEXT_PUBLIC_SITE_URL=http://localhost:4028 + register that callback URL.
# Paste your real client id from the partner portal (do not use example strings).
NEXT_PUBLIC_DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
# Optional override (default: meripehchaan .../oauth2/2/files/issued)
# DIGILOCKER_ISSUED_URL=
